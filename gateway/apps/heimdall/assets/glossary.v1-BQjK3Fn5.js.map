      "id": "incoterm_exw",
      "term": "EXW (Ex Works)",
      "category": "incoterm",
      "shortDef": "Buyer collects at seller's premises; buyer bears all risk and cost.",
      "definition": "Ex Works is the Incoterm placing maximum responsibility on the buyer. The seller's only obligation is to make goods available at their named premises. The buyer arranges export clearance, transport, insurance, and import — and bears risk from the moment goods are placed at their disposal.",
      "applicableStages": ["origin"],
      "riskClass": "high",
      "regulatoryBody": "ICC",
      "relatedTermIds": ["incoterm_fca", "incoterm_ddp", "instrument_open_account"],
