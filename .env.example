# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# ── Voice settings (BMO — Adventure Time) ───────────────────────────────────
# BMO uses Kokoro af_heart + FX chain (no voice cloning by default).
# The bmo.wav clip is the phone-answer scene ("Ring ring hello football hello bemo")
# which F5-TTS echoes into every response — FX-only avoids this.
#
# To enable voice cloning for a DIFFERENT profile (e.g. 'megatron'):
#   1. Record/extract 5-15s of clean target voice → voices/megatron.wav
#   2. Set ENKIDU_DEFAULT_VOICE=megatron, ENKIDU_FORCE_VOICE_PROFILE=megatron
#   3. Remove 'megatron' from ENKIDU_FX_ONLY_PROFILES
#   4. Set ENKIDU_STREAM_CLONE=1 to route streaming through F5-TTS
#   5. Set ENKIDU_PITCH=0.0 (clone captures real pitch; don't double-shift)
#
# To extract a voice from YouTube automatically:
#   cd phase6-ui/server
#   python scan_bmo_voice.py <youtube_url> --out <profile_name>
ENKIDU_DEFAULT_VOICE=bmo
ENKIDU_FORCE_VOICE_PROFILE=bmo
ENKIDU_FX_ONLY_PROFILES=bmo   # skip F5-TTS/Chatterbox cloning for these profiles
ENKIDU_STREAM_CLONE=0
ENKIDU_AUTO_REF_TEXT=1
ENKIDU_PREWARM_F5=1
ENKIDU_F5_TIMEOUT=30
ENKIDU_F5_MAX_FAILS=3

# Kokoro fallback voice (used when F5-TTS is unavailable)
# American voices need KOKORO_LANG=a, British voices need KOKORO_LANG=b
KOKORO_VOICE=af_heart
KOKORO_SPEED=0.84
KOKORO_LANG=a

# ── Character FX chain ───────────────────────────────────────────────────────
# Applied on top of clone output (ENKIDU_MEGATRON=1 enables the chain).
# These defaults are tuned for BMO's small-speaker warmth. Adjust to taste.
ENKIDU_MEGATRON=1
ENKIDU_PITCH=5.5            # semitones; +5.5 for BMO's high pitch (FX-only mode); 0 if cloning
ENKIDU_FORMANT=1.06         # >1 brightens timbre (small speaker character)
ENKIDU_LOW_BOOST=0.0        # dB bass shelf (off — BMO is a small speaker)
ENKIDU_DRIVE=1.4            # soft-clip warmth; lower = cleaner consonants; >3.0 = aggressive growl
ENKIDU_VOC_MIX=0.05         # vocoder blend (0 = off, higher = more robotic)
ENKIDU_VOC_BASE=380         # vocoder carrier Hz (higher = brighter electronic tone)
ENKIDU_RING_HZ=0.0          # ring mod frequency; 0 = off
ENKIDU_RING_DEPTH=0.0       # ring mod depth; 0 = off
ENKIDU_COMB_MS=2.0          # comb filter delay ms (shorter = small speaker box)
ENKIDU_COMB_FB=0.22         # comb feedback (0 = off, 0.6 = heavy resonance)
ENKIDU_COMB_MIX=0.12        # comb wet/dry
ENKIDU_CRUSH_MIX=0.06       # bitcrusher blend (0 = off, higher = more lo-fi)
ENKIDU_CRUSH_BITS=13        # bitcrusher depth (13 = subtle, 8 = heavy 8-bit)
ENKIDU_CRUSH_DECIM=1        # sample-rate decimation (1 = off)
ENKIDU_CHEST_HZ=1400        # presence peak center Hz
ENKIDU_CHEST_DB=2.5         # presence peak gain dB
ENKIDU_CHEST_Q=2.0          # presence peak Q (width)
ENKIDU_BITE_HZ=2200         # upper presence peak center Hz
ENKIDU_BITE_DB=2.5          # upper presence peak gain dB
ENKIDU_BITE_Q=1.5           # upper presence peak Q
ENKIDU_SIB_HZ=6500          # sibilance shelf start Hz
ENKIDU_SIB_DB=2.0           # sibilance shelf gain dB
ENKIDU_VERB_MS=20           # reverb pre-delay ms (20 = small room/speaker box)
ENKIDU_VERB_MIX=0.04        # reverb wet/dry (0 = dry, 0.4 = very roomy)

# Path to ffmpeg bin/ directory (used by voice pipeline).
# Leave blank if ffmpeg is already on your system PATH.
FFMPEG_DIR=C:\ffmpeg\bin\ffmpeg-master-latest-win64-gpl-shared\ffmpeg-master-latest-win64-gpl-shared\bin

# ── API keys ─────────────────────────────────────────────────────────────────
# Required: Anthropic Claude API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Tavily API for internet search — https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_ALLOWED_USER_ID=<your-telegram-user-id>

# ── Paths (machine-specific) ──────────────────────────────────────────────────
# Root of your QuantitativeValue project (for portfolio CSV + EDGAR screener).
QV_PATH=C:\Users\<you>\QuantitativeValue

# Path to Enkidu GitHub App private key (for autonomous bot commits).
ENKIDU_GITHUB_PRIVATE_KEY_PATH=C:\Users\<you>\.secrets\enkidu.private-key.pem

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
ENKIDU_FORCE_LOCAL_ONLY=0

# ── GitHub App (autonomous bot commits) ──────────────────────────────────────
ENKIDU_GITHUB_APP_ID=<app-id>
ENKIDU_GITHUB_INSTALLATION_ID=<installation-id>

# ── Lighting ──────────────────────────────────────────────────────────────────
ENKIDU_ENABLE_LIGHTING=1
ENKIDU_LIGHTING_ALIENFX=1
ENKIDU_LIGHTING_CORSAIR=0
