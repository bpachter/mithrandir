# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# ── Voice settings (Kokoro-first, low-latency) ──────────────────────────────
# Default Mithrandir stack: Kokoro British male, with optional F5 reference clone.
MITHRANDIR_DEFAULT_VOICE=bm_george
MITHRANDIR_FORCE_VOICE_PROFILE=
MITHRANDIR_STREAM_CLONE=0
MITHRANDIR_CLONE_TARGETS=
MITHRANDIR_AUTO_REF_TEXT=0
MITHRANDIR_PREWARM_F5=0
MITHRANDIR_F5_STARTUP_TIMEOUT=180
MITHRANDIR_F5_TIMEOUT=30
MITHRANDIR_F5_MAX_FAILS=2

# Kokoro voice configuration
# American voices need KOKORO_LANG=a, British voices need KOKORO_LANG=b.
KOKORO_VOICE=bm_george
KOKORO_SPEED=0.84
KOKORO_LANG=b

# Voice websocket payload limits (defensive hardening)
MITHRANDIR_VOICE_MAX_B64_CHARS=8000000
MITHRANDIR_VOICE_MAX_RAW_BYTES=5000000
MITHRANDIR_VOICE_MIN_SAMPLE_RATE=8000
MITHRANDIR_VOICE_MAX_SAMPLE_RATE=48000

# ── Character FX chain ───────────────────────────────────────────────────────
# Applied on top of F5/StyleTTS2 output (MITHRANDIR_FX_ENABLED=1 enables the chain).
MITHRANDIR_FX_ENABLED=1
MITHRANDIR_PITCH=-1.5
MITHRANDIR_FORMANT=0.93
MITHRANDIR_LOW_BOOST=4.0
MITHRANDIR_LOW_CUTOFF=300
MITHRANDIR_SUB_MIX=0.0
MITHRANDIR_DRIVE=1.6
MITHRANDIR_VOC_MIX=0.0
MITHRANDIR_VOC_BASE=380
MITHRANDIR_RING_HZ=0.0
MITHRANDIR_RING_DEPTH=0.0
MITHRANDIR_COMB_MS=2.0
MITHRANDIR_COMB_FB=0.0
MITHRANDIR_COMB_MIX=0.0
MITHRANDIR_CRUSH_MIX=0.0
MITHRANDIR_CRUSH_BITS=16
MITHRANDIR_CRUSH_DECIM=1
MITHRANDIR_CHEST_HZ=230
MITHRANDIR_CHEST_DB=5.0
MITHRANDIR_CHEST_Q=2.0
MITHRANDIR_BITE_HZ=3200
MITHRANDIR_BITE_DB=2.5
MITHRANDIR_BITE_Q=1.5
MITHRANDIR_SIB_HZ=7500
MITHRANDIR_SIB_DB=2.0
MITHRANDIR_VERB_MS=65
MITHRANDIR_VERB_FB=0.32
MITHRANDIR_VERB_MIX=0.10

# Path to ffmpeg bin/ directory (used by voice pipeline).
# Leave blank if ffmpeg is already on your system PATH.
FFMPEG_DIR=C:\ffmpeg\bin\ffmpeg-master-latest-win64-gpl-shared\ffmpeg-master-latest-win64-gpl-shared\bin

# ── API keys ─────────────────────────────────────────────────────────────────
# Required: Anthropic Claude API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Tavily API for internet search — https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_ALLOWED_USER_ID=<your-telegram-user-id>

# ── Paths (machine-specific) ──────────────────────────────────────────────────
# Root of your QuantitativeValue project (for portfolio CSV + EDGAR screener).
QV_PATH=C:\Users\<you>\QuantitativeValue

# Path to Mithrandir GitHub App private key (for autonomous bot commits).
MITHRANDIR_GITHUB_PRIVATE_KEY_PATH=C:\Users\<you>\.secrets\mithrandir.private-key.pem

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Optional explicit alias used by phase3 agent (falls back to OLLAMA_HOST).
OLLAMA_URL=http://localhost:11434

# Primary deep reasoning model (secondary lane in dual-lane setup).
OLLAMA_MODEL=gemma4:26b
# Primary conversational fast model (primary lane in dual-lane setup).
# Recommended on 4090: qwen2.5:7b (or llama3.1:8b if preferred).
OLLAMA_FAST_MODEL=
# Optional dedicated model for local ReAct tool loop.
OLLAMA_REACT_MODEL=

# Dual-lane and latency behavior controls.
MITHRANDIR_FAST_LANE=1
MITHRANDIR_SPOKEN_MAX_TOKENS=384
MITHRANDIR_SHORT_REPLY_MAX_TOKENS=160
MITHRANDIR_REACT_MAX_TOKENS=768
MITHRANDIR_REACT_MAX_ITERATIONS=6
MITHRANDIR_REACT_SPOKEN_MAX_ITERATIONS=4
MITHRANDIR_REACT_TOOL_TRUNCATE_CHARS=1600
MITHRANDIR_FORCE_LOCAL_ONLY=0
# Agent execution mode: local_react (default, Gemma tools), cloud (Claude tools)
MITHRANDIR_AGENT_MODE=local_react
# Optional separate upstream for /ws/voice proxy (if different tunnel/domain than API).
VOICE_GPU_URL=
# Gateway voice proxy cooldown (seconds) after upstream websocket failures.
VOICE_UPSTREAM_COOLDOWN_SEC=20

# Optional specialist delegation while keeping Gemma as primary orchestrator.
MITHRANDIR_CLAUDE_SUBAGENT_ENABLED=1
CLAUDE_SUBAGENT_MODEL=claude-sonnet-4-6
# Deterministic delegation gate controls.
MITHRANDIR_CLAUDE_SUBAGENT_TOKEN_THRESHOLD=9000
MITHRANDIR_CLAUDE_SUBAGENT_ALLOWLIST=long context,document analysis,multi-file,codebase synthesis,second opinion,validation,refactor
MITHRANDIR_CLAUDE_SUBAGENT_MAX_CALLS=6
MITHRANDIR_CLAUDE_SUBAGENT_WINDOW_SEC=60
# Optional overrides and logging.
MITHRANDIR_CLAUDE_SUBAGENT_FORCE=0
MITHRANDIR_CLAUDE_SUBAGENT_AUDIT_LOG=phase3-agents/claude_subagent_audit.jsonl

# ── GitHub App (autonomous bot commits) ──────────────────────────────────────
MITHRANDIR_GITHUB_APP_ID=<app-id>
MITHRANDIR_GITHUB_INSTALLATION_ID=<installation-id>

# ── Lighting ──────────────────────────────────────────────────────────────────
MITHRANDIR_ENABLE_LIGHTING=1
MITHRANDIR_LIGHTING_ALIENFX=1
MITHRANDIR_LIGHTING_CORSAIR=0
